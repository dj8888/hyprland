/*
# === Tracked: un-ignore so config is complete when switching systems ===
!.gitignore
!README.md
!buildPDF.md
# Desktop / Hyprland
!hypr/
hypr/previous_wallpaper
hypr/wallpaper_state
!waybar/
!swaync/
!swayosd/
!wlogout/
!wofi/
!kitty/
!tmux/
!zsh/
zsh/.zsh_history
zsh/.zcompdump
!.zshenv
!yazi/
!yt-dlp/
# Pacman: hooks (symlink into /etc/pacman.d/hooks) + options to reapply on new installs
!pacman/
# buildPDF: optional mermaid-cli puppeteer config
!mermaid/
!fastfetch/
# Claude Code: profile dirs — only settings.json is safe to track
!claude/
!claude/personal/
!claude/work/
claude/personal/*
claude/work/*
claude/personal/settings.json
claude/work/settings.
#submodules
!nvim
